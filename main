    <!-- UI Routing Interactive States Execution Script -->
    <script>
        function selectDifferenceTab(activeTabId) {
            document.querySelectorAll('.diff-pane').forEach(pane => {
                pane.classList.add('hidden');
                pane.classList.remove('block');
            });
            document.querySelectorAll('.diff-tab-btn').forEach(btn => {
                btn.classList.remove('border-2');
                btn.classList.add('bg-slate-900/50', 'border', 'border-slate-800/80');
                btn.style.borderColor = '';
                btn.querySelector('h4').classList.remove('font-bold', 'text-white');
                btn.querySelector('h4').classList.add('font-semibold', 'text-slate-300');
                
                const svgIcon = btn.querySelector('svg');
                if (svgIcon) {
                    svgIcon.className.baseVal = "w-5 h-5 text-slate-500";
                }
            });

            const activeBtn = document.getElementById('diff-btn-' + activeTabId);
            activeBtn.classList.remove('bg-slate-900/50', 'border', 'border-slate-800/80');
            
            let colorSpec = '#FF007A';
            if (activeTabId === 'disclosure-tab') colorSpec = '#00F5D4';
            if (activeTabId === 'analytics-tab') colorSpec = '#a855f7';
            
            activeBtn.classList.add('border-2');
            activeBtn.style.borderColor = colorSpec;
            activeBtn.querySelector('h4').classList.remove('font-semibold', 'text-slate-300');
            activeBtn.querySelector('h4').classList.add('font-bold', 'text-white');

            const activeSvg = activeBtn.querySelector('svg');
            if (activeSvg) {
                activeSvg.style.color = colorSpec;
                activeSvg.className.baseVal = "w-5 h-5";
            }

            document.getElementById('diff-content-' + activeTabId).classList.remove('hidden');
            document.getElementById('diff-content-' + activeTabId).classList.add('block');
        }

        const bookDatabase = [
            {
                serial: "Volume 01 // Structural Strategy",
                title: "The 2026 Hotline Program Architecture Manual",
                desc: "Comprehensive deployment systems blueprints mapping client processing routing metrics across operational silos.",
                color: "linear-gradient(to bottom, #FF007A, #a855f7)"
            },
            {
                serial: "Volume 02 // Behavioral Data",
                title: "Deciphering Corporate Empathy Gap Metrics",
                desc: "Statistical analysis protocols analyzing exactly why reporting pipelines fail inside typical operational hierarchies.",
                color: "linear-gradient(to bottom, #00F5D4, #3b82f6)"
            },
            {
                serial: "Volume 03 // Defensibility Specification",
                title: "The Defensible Program Defense Ledger",
                desc: "Regulatory evidence design principles mapping documentation parameters requested by government review commissions.",
                color: "linear-gradient(to bottom, #a855f7, #pink-500)"
            }
        ];
        
        let currentBookIndex = 0;

        function slideBook(direction) {
            if (direction === 'next') {
                currentBookIndex = (currentBookIndex + 1) % bookDatabase.length;
            } else {
                currentBookIndex = (currentBookIndex - 1 + bookDatabase.length) % bookDatabase.length;
            }
            
            const targetBook = bookDatabase[currentBookIndex];
            document.getElementById('book-serial').innerText = targetBook.serial;
            document.getElementById('book-title').innerText = targetBook.title;
            document.getElementById('book-desc').innerText = targetBook.desc;
            document.getElementById('book-spine-accent').style.background = targetBook.color;
        }
    </script>
</body>
